# ── PRODUCTION (Vercel dashboard) ────────────────────────────────────────────
# Set this in Vercel → Project → Settings → Environment Variables.
# The key lives server-side only — never sent to the browser.
GEMINI_API_KEY=

# ── LOCAL DEV fallback (npm run dev without vercel dev) ──────────────────────
# Only needed if you run plain `npm run dev` instead of `vercel dev`.
# Stays in .env (gitignored). Never add this to Vercel — it would leak into the bundle.
VITE_GEMINI_API_KEY=

# ── Optional overrides ────────────────────────────────────────────────────────
# VITE_GEMINI_MODEL=gemini-2.5-flash
